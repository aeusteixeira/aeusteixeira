	DefineInfo 0x0405
		Name = "Rek"
		Description = "Kdy‍ spadnete do rokle, zavolلte Lassie. Kdy‍ potّebujete pomoci v aplikacيch Office, zavolلte Reka."
		ExtraData = "Mلte dotaz? Pus‌te mى do prلce.~~Problém? Uvolnىte se, vيm jak na to.~~Nedىlejte si starosti, jsem vytrénovلn pro Office.^^A je to tady.~~Toto jste chtىli pّipomenout."
